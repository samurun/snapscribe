# Snapscribe — local development env
# Copy to `.env`. This file is for running infra in Docker while web/api/worker
# run on the host (`pnpm dev`, `bun run dev`, `uv run python worker.py`).
# For one-command Docker self-host, use `.env.prod.example` instead.

# === Postgres ===
POSTGRES_USER=snapscribe
POSTGRES_PASSWORD=snapscribe
POSTGRES_DB=snapscribe
POSTGRES_HOST_PORT=5433
DATABASE_URL=postgres://snapscribe:snapscribe@localhost:5433/snapscribe

# === MinIO (S3-compatible) ===
MINIO_ROOT_USER=snapscribe
MINIO_ROOT_PASSWORD=snapscribe-secret
MINIO_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_SECURE=false
S3_ACCESS_KEY=snapscribe
S3_SECRET_KEY=snapscribe-secret
S3_BUCKET=snapscribe

# === RabbitMQ ===
RABBITMQ_USER=snapscribe
RABBITMQ_PASSWORD=snapscribe
RABBITMQ_HOST_PORT=5672
RABBITMQ_MGMT_HOST_PORT=15672
AMQP_URL=amqp://snapscribe:snapscribe@localhost:5672
QUEUE_NAME=jumpcut

# === Web → API URL (baked into Next.js build) ===
NEXT_PUBLIC_API_BASE=http://localhost:3001

# === Host port mapping (Docker) ===
API_HOST_PORT=3001
WEB_HOST_PORT=3000

# === GCP Chirp transcriber ===
GCP_PROJECT=your-gcp-project
GCP_BUCKET=your-gcs-bucket
GCP_LOCATION=us-central1
CHIRP_MODEL=chirp_2
CHIRP_LANGUAGE=th-TH
TRANSCRIBER_BACKEND=chirp
