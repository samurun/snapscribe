# Snapscribe — self-host / VPS env
# Copy to `.env` then run `pnpm apptear:up`. Everything runs in Docker —
# the host only needs Docker + Compose v2.
#
# IMPORTANT: change every password before exposing this stack to the network.

# === Postgres ===
POSTGRES_USER=snapscribe
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=snapscribe
POSTGRES_HOST_PORT=5433

# === MinIO ===
MINIO_ROOT_USER=snapscribe
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
S3_REGION=us-east-1
S3_BUCKET=snapscribe
# External URLs when exposed through Caddy. Leave empty for local-only access.
MINIO_SERVER_URL=https://s3.snapscribe.duckdns.org
MINIO_BROWSER_REDIRECT_URL=https://console.snapscribe.duckdns.org

# === RabbitMQ ===
RABBITMQ_USER=snapscribe
RABBITMQ_PASSWORD=change-me-rabbit
RABBITMQ_HOST_PORT=5672
RABBITMQ_MGMT_HOST_PORT=15672
QUEUE_NAME=jumpcut

# === Host ports for app services ===
API_HOST_PORT=3001
WEB_HOST_PORT=3000

# === Web → API URL ===
# This is baked into the Next.js bundle at build time. It must be reachable
# FROM THE BROWSER, so use the host/IP that users will type into their browser.
# Examples:
#   http://localhost:3001          (running on the same machine)
#   http://192.168.1.50:3001       (LAN access)
#   http://snapscribe.example.com:3001
# After changing this value, run `pnpm apptear:rebuild` to re-bake the bundle.
NEXT_PUBLIC_API_BASE=https://snapscribe.duckdns.org/api

# === Caddy (reverse proxy + HTTPS) ===
# Domain points to the VM's external IP. Caddy auto-provisions Let's Encrypt cert.
# Requires firewall ports 80 + 443 open.
CADDY_DOMAIN=snapscribe.duckdns.org
CADDY_EMAIL=you@example.com

# === GCP Chirp transcriber ===
# Place your service-account JSON at ./secrets/gcp-sa.json on the host.
# The worker container mounts it read-only at /gcp/sa.json.
# The service account needs roles: roles/speech.client, roles/storage.objectAdmin
# If LLM_SEGMENT_REFINER=1, also add: roles/aiplatform.user (for Vertex AI Gemini).
TRANSCRIBER_BACKEND=chirp
GCP_PROJECT=your-gcp-project
GCP_BUCKET=your-gcs-bucket
GCP_LOCATION=us-central1
CHIRP_MODEL=chirp_2
CHIRP_LANGUAGE=th-TH

# === Gemini segment refiner (optional) ===
# Set LLM_SEGMENT_REFINER=1 to re-segment Chirp transcripts via Gemini for
# TikTok-style phrase-boundary subtitles. Requires Vertex AI API enabled on
# GCP_PROJECT and the service account to have roles/aiplatform.user.
# Cost: ~$0.0002/video (~฿0.01) with flash-lite. Falls back silently to the
# rule-based grouper on any failure. Leave at 0 to disable.
LLM_SEGMENT_REFINER=0
GEMINI_MODEL=gemini-2.5-flash-lite

# === Worker ===
MAX_RETRIES=3

# === Clerk auth ===
# Get keys from dashboard.clerk.com → API Keys.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY is baked into the Next.js bundle at build time —
# rebuild after changing it. CLERK_PUBLISHABLE_KEY mirrors the same value for the API.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/sign-in