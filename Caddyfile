{
	email {$CADDY_EMAIL:admin@snapscribe.local}
}

{$CADDY_DOMAIN:localhost} {
	encode zstd gzip

	handle_path /api/* {
		reverse_proxy api:3001
	}

	handle {
		reverse_proxy web:3000
	}
}

console.{$CADDY_DOMAIN:localhost} {
	encode zstd gzip
	reverse_proxy minio:9001
}

s3.{$CADDY_DOMAIN:localhost} {
	encode zstd gzip
	reverse_proxy minio:9000
}

rabbitmq.{$CADDY_DOMAIN:localhost} {
	encode zstd gzip
	reverse_proxy rabbitmq:15672
}
